NODE_ENV=production
PORT=5000
DB_HOST=YOUR_DB_HOST
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=YOUR_DB_NAME

# Optional AI feature
OPENAI_API_KEY=

# Comma-separated allowlist (no wildcard)
CORS_ALLOWED_ORIGINS=https://frontend.example.com,https://admin.example.com

# Auth and admin
ADMIN_EMAILS=admin@example.com
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=ChangeMe_123!
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ISSUER=uboncity-backend
JWT_AUDIENCE_BACKEND=uboncity-backend
JWT_AUDIENCE_COLLECTOR=uboncity-collector
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# Public/base URLs
BACKEND_PUBLIC_URL=https://your-backend-domain.onrender.com
GOOGLE_MAPS_BROWSER_KEY=

# Internal sync token for collector -> backend lifecycle import
LIFECYCLE_SYNC_TOKEN=REPLACE_WITH_LONG_RANDOM_SYNC_TOKEN

# Web review -> collector callback (required when needs_revision flow is enabled)
COLLECTOR_SYNC_BASE_URL=https://collector.internal.example
COLLECTOR_REVIEW_SYNC_TOKEN=REPLACE_WITH_LONG_RANDOM_REVIEW_SYNC_TOKEN

# Integration readiness rollout switches
# Keep these at 0 until the corresponding URLs/tokens are provisioned in the target environment.
# Set to 1 only when that integration must fail-fast at startup.
REQUIRE_REVIEW_COLLECTOR_SYNC=0
REQUIRE_COLLECTOR_LIFECYCLE_SYNC=0
REQUIRE_COLLECTOR_TRANSPORT_SYNC=0
