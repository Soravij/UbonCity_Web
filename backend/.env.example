# ============================
# Backend - UbonCity Web
# ============================

# ===== Runtime / Server =====
NODE_ENV=production
PORT=5000

# ===== Database =====
DB_HOST=YOUR_DB_HOST
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=YOUR_DB_NAME

# ===== AI (General) =====
# Backend is the single secret boundary for internal AI execution.
OPENAI_API_KEY=
OPENAI_API_KEY_ASK=
OPENAI_MODEL_ASK=gpt-5.3-codex

# ===== Translation Provider Selection =====
# openai | google
TRANSLATION_AI_PROVIDER=openai
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
GOOGLE_AI_API_KEY=
GOOGLE_TRANSLATE_MODEL=gemini-2.0-flash
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ===== CORS =====
# Comma-separated allowlist (no wildcard)
CORS_ALLOWED_ORIGINS=https://frontend.example.com,https://admin.example.com

# ===== Auth & Admin =====
ADMIN_EMAILS=admin@example.com
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=ChangeMe_123!
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ISSUER=uboncity-backend
JWT_AUDIENCE_BACKEND=uboncity-backend
JWT_AUDIENCE_COLLECTOR=uboncity-collector
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# ===== Public / Base URLs =====
BACKEND_PUBLIC_URL=https://your-backend-domain.onrender.com
GOOGLE_MAPS_BROWSER_KEY=

# ===== Internal Sync (Collector) =====
LIFECYCLE_SYNC_TOKEN=REPLACE_WITH_LONG_RANDOM_SYNC_TOKEN
COLLECTOR_SYNC_BASE_URL=https://collector.internal.example
COLLECTOR_REVIEW_SYNC_TOKEN=REPLACE_WITH_LONG_RANDOM_REVIEW_SYNC_TOKEN

# ===== Integration Readiness Switches =====
# Keep these at 0 until the corresponding URLs/tokens are provisioned.
REQUIRE_REVIEW_COLLECTOR_SYNC=0
REQUIRE_COLLECTOR_LIFECYCLE_SYNC=0
REQUIRE_COLLECTOR_TRANSPORT_SYNC=0
