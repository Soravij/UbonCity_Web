# ============================
# Collector - UbonCity Web
# ============================

# ===== Runtime / Server =====
NODE_ENV=production
PORT=5070
# Collector is internal/private only. Keep firewall closed for this port from public internet.
COLLECTOR_BIND_HOST=127.0.0.1

# ===== Preferred Bootstrap Owner =====
OWNER_EMAIL=owner@uboncity.local
OWNER_NAME=System Owner

# ===== AI Credentials / Transport =====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GOOGLE_AI_API_KEY=
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ===== AI Policy =====
# Owner panel is the source of truth for feature -> model policy.
# Runtime no longer reads per-feature AI routing from env.

# ===== Maps / Search / Translation Targets =====
GOOGLE_MAPS_API_KEY=
GOOGLE_CUSTOM_SEARCH_JSON_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
# Legacy aliases still supported for backward compatibility:
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
TRANSLATION_TARGET_LANGS=en,zh,lo

# ===== CORS =====
# Access control: explicit allowlist only (no wildcard)
CORS_ALLOWED_ORIGINS=https://admin.internal.example

# ===== Optional Paths =====
# DB_PATH=./data/collector.db
# RAW_DIR=./raw
# STAGING_DIR=./staging/content
# EXPORT_DIR=./staging/content
# MEDIA_DIR=./media

# ===== Backend / Sync =====
COLLECTOR_PUBLIC_BASE_URL=https://collector.internal.example
COLLECTOR_SYNC_BACKEND_API=https://backend.internal.example/api
# Optional aliases supported by runtime:
# BACKEND_API_BASE_URL=https://backend.internal.example/api
# BACKEND_URL=https://backend.internal.example/api

# ===== Auth (Backend JWT) =====
BACKEND_JWT_SECRET=REPLACE_WITH_SHARED_BACKEND_JWT_SECRET
BACKEND_JWT_ISSUER=uboncity-backend
COLLECTOR_BACKEND_JWT_AUDIENCE=uboncity-collector
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# ===== Internal Sync Tokens =====
LIFECYCLE_SYNC_TOKEN=REPLACE_WITH_LONG_RANDOM_SYNC_TOKEN
COLLECTOR_REVIEW_SYNC_TOKEN=REPLACE_WITH_LONG_RANDOM_REVIEW_SYNC_TOKEN

# ===== Integration Readiness Switches =====
# Keep these at 0 until corresponding URLs/tokens are provisioned.
REQUIRE_COLLECTOR_PUBLISH_SYNC=0
REQUIRE_COLLECTOR_TRANSPORT_SYNC=0
REQUIRE_COLLECTOR_REVIEW_FEEDBACK=0

# ===== Shared Local Test Toolkit (Optional) =====
# COLLECTOR_TEST_BASE_URL=http://127.0.0.1:5070
# COLLECTOR_TEST_AUTH_MODE=backend_jwt
# COLLECTOR_TEST_EMAIL=owner@uboncity.local
# COLLECTOR_TEST_PASSWORD=REPLACE_IF_USING_LOGIN_MODE
# COLLECTOR_TEST_USER_ID=1
# COLLECTOR_TEST_USER_ROLE=admin
# COLLECTOR_TEST_USER_NAME=Collector Test User
# COLLECTOR_TEST_ITEM_ID=44
# COLLECTOR_TEST_TOKEN_CACHE=./data/tmp-collector-test-token.json
# COLLECTOR_TEST_TOKEN_TTL=1h

# ===== Assignment Work/Review Smoke (Optional) =====
# BACKEND_AUTH_EMAIL=owner@uboncity.local
# BACKEND_AUTH_PASSWORD=REPLACE_OWNER_PASSWORD
# COLLECTOR_ASSIGNMENT_SMOKE_OWNER_EMAIL=owner@uboncity.local
# COLLECTOR_ASSIGNMENT_SMOKE_OWNER_PASSWORD=REPLACE_OWNER_PASSWORD
# COLLECTOR_ASSIGNMENT_SMOKE_USER_EMAIL=worker@uboncity.local
# COLLECTOR_ASSIGNMENT_SMOKE_USER_PASSWORD=REPLACE_USER_PASSWORD
